# QCLaw Frontend Dockerfile
FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY webui/package*.json ./webui/

# Install dependencies
WORKDIR /app/webui
RUN npm ci

# Copy application code
COPY webui/ ./

# Build application
RUN npm run build

# Use nginx to serve static files
FROM nginx:alpine
COPY --from=0 /app/webui/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
