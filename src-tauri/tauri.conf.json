{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QCLaw",
  "version": "1.0.0",
  "identifier": "com.qclaw.app",
  "build": {
    "frontendDist": "../webui/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd webui && npm run dev",
    "beforeBuildCommand": "cd webui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QCLaw 智能量化分析平台",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
